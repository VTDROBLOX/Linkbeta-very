-- Bảng chống spam dữ liệu liên tục lên Render
local active = {}

-- Hàm kiểm tra Sea tự động
local function getSea()
    local id = game.PlaceId
    if id == 4442232693 or id == 4442272183 then return 2 end
    if id == 4442247956 or id == 7449423635 then return 3 end
    return 0
end

-- Hàm gửi dữ liệu Boss/Đảo lên cổng đa nhiệm /update-game
local function sendGameData(eventType)
    pcall(function()
        req({
            Url = "https://api-server-clig.onrender.com/update-game",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = game:GetService("HttpService"):JSONEncode({
                jobId = tostring(game.JobId),
                players = #game:GetService("Players"):GetPlayers(),
                placeId = game.PlaceId,
                type = eventType
            })
        })
    end)
end

-- Hàm check điều kiện xuất hiện an toàn
local function check(name, eventType, cond)
    local ok = false
    pcall(function() ok = cond() end)
    if ok then
        if not active[name] then
            active[name] = true
            sendGameData(eventType)
        end
    else
        active[name] = nil
    end
end

-- Hàm định vị Boss trong Workspace
local function findEnemy(name)
    local enemies = workspace:FindFirstChild("Enemies")
    return function()
        return game:GetService("ReplicatedStorage"):FindFirstChild(name) 
            or (enemies and enemies:FindFirstChild(name))
    end
end

-- 2. LUỒNG CHẠY NGẦM QUÉT TỔNG HỢP (Chu kỳ quét: 10 giây/lần cho nhẹ game)
spawn(function()
    while true do
        local sea = getSea()
        local lighting = game:GetService("Lighting")
        local sky = lighting:FindFirstChildOfClass("Sky") or lighting:FindFirstChild("Sky")
        
        -- ====== A. QUÉT TRĂNG TRÒN (Giữ nguyên cổng /update-moon cũ đúng ý bạn) ======
        if sky and (string.find(string.lower(sky.MoonTextureId), "9709149431") or string.find(string.lower(sky.MoonTextureId), "full")) then
            local myData = { jobId = tostring(game.JobId), players = #game:GetService("Players"):GetPlayers() }
            pcall(function()
                req({
                    Url = "https://api-server-clig.onrender.com/update-moon",
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = game:GetService("HttpService"):JSONEncode(myData)
                })
            end)
        end

        -- ====== B. QUÉT BOSS TẠI SEA 2 ======
        if sea == 2 then
            check("captain", "CursedCaptain", findEnemy("Cursed Captain")) -- Cursed Captain
        end

        -- ====== C. QUÉT BOSS & ĐẢO TẠI SEA 3 ======
        if sea == 3 then
            check("rip", "RipIndra", findEnemy("Rip Indra"))          -- Rip Indra
            check("doughv2", "KatakuriV2", findEnemy("Dough King"))    -- Katakuri V2
            check("reaper", "SoulReaper", findEnemy("Soul Reaper"))    -- Soul Reaper

            -- Quét Đảo Kì Bí (Mirage Island)
            local loc = workspace:FindFirstChild("_WorldOrigin")
            loc = loc and loc:FindFirstChild("Locations")
            if loc then
                check("mirage", "Mirage", function()
                    return loc:FindFirstChild("Mirage Island")
                end)
            end
        end

        task.wait(10) -- Quét liên tục mỗi 10 giây
    end
end)

