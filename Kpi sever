local active = {}

-- LOGIC MỚI: Check Sea dựa trên Badge/Tên địa danh thực tế thay vì check ID số dễ lỗi
local function getRealSea()
    local titleName = game:GetService("Players").LocalPlayer defense or ""
    -- Dựa vào việc tìm kiếm các hòn đảo đặc trưng trong Workspace để xác định Sea
    if workspace:FindFirstChild("Ghost Ship") or workspace:FindFirstChild("Ice Castle") then
        return 2
    elseif workspace:FindFirstChild("Sea Beast Spawner") or workspace:FindFirstChild("Turtle") or workspace:FindFirstChild("Hydra Island") then
        return 3
    end
    
    -- Cách dự phòng 2: Quét lại theo ID mặc định nếu không tìm thấy object
    local id = game.PlaceId
    if id == 4442232693 or id == 4442272183 then return 2 end
    if id == 4442247956 or id == 7449423635 or tostring(game.JobId) ~= "" then return 3 end -- Ép về Sea 3 nếu là phòng con
    return 3
end

local function sendGameData(eventType)
    pcall(function()
        req({
            Url = "https://api-server-clig.onrender.com/update-game",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = Http:JSONEncode({
                jobId = tostring(game.JobId),
                players = #game:GetService("Players"):GetPlayers(),
                placeId = game.PlaceId,
                type = eventType
            })
        })
    end)
end

local function check(name, eventType, cond)
    local ok = false
    pcall(function() ok = cond() end)
    if ok then
        if not active[name] then
            active[name] = true
            sendGameData(eventType)
        end
    else
        active[name] = nil
    end
end

local function findEnemy(name)
    local enemies = workspace:FindFirstChild("Enemies")
    return function()
        return game:GetService("ReplicatedStorage"):FindFirstChild(name) 
            or (enemies and enemies:FindFirstChild(name))
    end
end

