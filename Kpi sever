print("")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local Lighting = game:GetService("Lighting")

local request_fn = (syn and syn.request) or (http and http.request) or http_request or request
if not request_fn then return end

-- Cấu hình API của Tùng
local API_URL = "https://api-server-clig.onrender.com"
local active = {}

-- 1. TĂNG LƯỢT EXECUTE CHUẨN
pcall(function()
    request_fn({ Url = API_URL .. "/execute", Method = "POST" })
end)

-- 2. HÀM CHECK SEA CẬP NHẬT MỌI PHÒNG CON (Fix kẹt số 0)
local function getSea()
    local id = game.PlaceId
    -- ID gốc và ID cụm phòng phụ Sea 1
    if id == 2753915549 or id == 85211729168715 then return 1 end
    -- ID gốc và ID cụm phòng phụ Sea 2
    if id == 4442232693 or id == 4442272183 or id == 79091703265657 then return 2 end
    -- ID gốc và ID cụm phòng phụ Sea 3 (Bypass hoàn toàn cụm server v31 mới của Tùng)
    if id == 4442247956 or id == 7449423635 or id == 100117331123089 or tostring(game.JobId) ~= "" then return 3 end
    return 3
end

-- 3. HÀM GỬI GAME DATA ĐA NHIỆM VỀ CỔNG MỚI
local function sendGameData(eventType)
    pcall(function()
        request_fn({
            Url = API_URL .. "/update-game",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({
                jobId = tostring(game.JobId),
                players = #Players:GetPlayers(),
                placeId = game.PlaceId,
                type = eventType
            })
        })
    end)
end

-- 4. HÀM CHECK ĐIỀU KIỆN CHỐNG SPAM RENDER
local function check(name, eventType, cond)
    local ok = false
    pcall(function() ok = cond() end)
    if ok then
        if not active[name] then
            active[name] = true
            sendGameData(eventType)
            print("[SUCCESS] Đã gửi sự kiện lên Web: " .. eventType)
        end
    else
        active[name] = nil
    end
end

-- 5. HÀM ĐỊNH VỊ BOSS CHUẨN KHÔNG SÓT MỘT CON (Bê nguyên từ Hub lớn)
local function enemy(name)
    return function()
        local Enemies = workspace:FindFirstChild("Enemies")
        return RS:FindFirstChild(name)
            or (Enemies and Enemies:FindFirstChild(name))
    end
end

-- 6. LUỒNG CHẠY NGẦM QUÉT TỔNG HỢP MỖI 5 GIÂY (Siêu tốc như Hub lớn)
task.spawn(function()
    while task.wait(5) do
        local sea = getSea()
        local sky = Lighting:FindFirstChildOfClass("Sky") or Lighting:FindFirstChild("Sky")

        -- ====== A. QUÉT CHU KỲ TRĂNG (Gửi về cổng cũ /update-moon) ======
        if sky then
            local moon = sky.MoonTextureId
            if moon == "http://www.roblox.com/asset/?id=9709149431" or string.find(string.lower(moon), "full") then
                pcall(function()
                    request_fn({
                        Url = API_URL .. "/update-moon",
                        Method = "POST",
                        Headers = { ["Content-Type"] = "application/json" },
                        Body = HttpService:JSONEncode({
                            jobId = tostring(game.JobId), 
                            players = #Players:GetPlayers() 
                        })
                    })
                end)
            end
        end

        -- ====== B. QUÉT SỰ KIỆN TẠI SEA 2 ======
        if sea == 2 then
            check("captain", "CursedCaptain", enemy("Cursed Captain"))
        end

        -- ====== C. QUÉT SỰ KIỆN TẠI SEA 3 (Tên chuẩn chữ hoa của game) ======
        if sea == 3 then
            check("rip", "RipIndra", enemy("Rip Indra"))
            check("doughv2", "KatakuriV2", enemy("Dough King"))
            check("reaper", "SoulReaper", enemy("Soul Reaper"))

            -- Quét các Đảo đặc biệt hệ thống gốc tòa độ
            local loc = workspace:FindFirstChild("_WorldOrigin")
            loc = loc and loc:FindFirstChild("Locations")
            if loc then
                check("mirage", "Mirage", function()
                    return loc:FindFirstChild("Mirage Island")
                end)
                check("volcano", "Volcano", function()
                    return loc:FindFirstChild("Prehistoric Island") or loc:FindFirstChild("Volcano Island")
                end)
            end
        end
    end
end)

